{
  "display_information": {
    "name": "Slack Detective",
    "description": "Investigates scattered workplace evidence and reconstructs what happened.",
    "background_color": "#1f1933"
  },
  "features": {
    "bot_user": {
      "display_name": "Slack Detective",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/detective",
        "description": "Investigate a workplace question",
        "usage_hint": "Why did checkout latency spike?",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": ["app_mention"]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
