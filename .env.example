PORT=3000
CONNECTOR_MODE=demo

# Optional: enables real Slack Socket Mode. The HTTP demo works without these.
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN=xapp-your-token
# SLACK_SIGNING_SECRET=your-signing-secret

# Optional: without this, deterministic local synthesis is used.
# OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini

# Optional override. Defaults to data/evidence.json.
DATA_PATH=data/evidence.json

# Optional real connector configuration. See CONNECTORS.md.
# Recommended real demo: seed a GitHub sandbox repo and query it through MCP.
# MCP_GITHUB_ENABLED=true
# MCP_GITHUB_COMMAND=npx -y @modelcontextprotocol/server-github
# GITHUB_TOKEN=github_pat_your-token
# GITHUB_OWNER=your-user-or-org
# GITHUB_DEMO_REPO=slack-detective-demo
# DEMO_SLACK_CHANNEL_ID=C0123456789

# Direct GitHub REST fallback/alternative. Ignored when GitHub MCP is fully configured.
# GITHUB_TOKEN=github_pat_your-token
# GITHUB_OWNER=your-org
# GITHUB_REPOS=repo-one,repo-two

# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECTS=OPS,ENG

# Use one Google auth method. Folder IDs are optional but recommended.
# GOOGLE_SERVICE_ACCOUNT_JSON=C:\path\to\service-account.json
# GOOGLE_ACCESS_TOKEN=ya29-your-token
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REFRESH_TOKEN=your-refresh-token
# GOOGLE_DRIVE_FOLDER_IDS=folder-id-1,folder-id-2

# Incident connector: use an HTTP endpoint or a production JSON file.
# INCIDENT_API_URL=https://incidents.example.com/api/incidents
# INCIDENT_API_TOKEN=your-incident-token
# INCIDENT_DATA_PATH=data\incidents.production.json
