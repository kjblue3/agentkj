PORT=3000
# HOST=127.0.0.1

# Slack Socket Mode; SLACK_WORKSPACE_ID maps static tokens to the single-workspace development fallback.
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_USER_TOKEN=xoxp-optional-search-token
# SLACK_APP_TOKEN=xapp-your-token
# SLACK_SIGNING_SECRET=your-signing-secret
# SLACK_WORKSPACE_ID=T0123456789
# For multi-workspace installation storage, omit the static bot token and configure:
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret
# SLACK_STATE_SECRET=long-random-install-state-secret

# Provider-compatible chat-completions backend. Multiple keys fail over and share cooldown state.
# LLM_API_KEYS=key-one,key-two
# LLM_API_KEY=single-key
# Optional Gemini keys are added to the same load-sharing pool.
# GEMINI_API_KEY_2=optional-second-gemini-key
# GEMINI_API_KEY_3=optional-third-gemini-key
# LLM_BASE_URL=https://api.example.test/openai/v1
LLM_MODEL=your-chat-model
# For Gemini backends: thinking-token budget per call (none|low|medium|high). Defaults to low.
# LLM_REASONING_EFFORT=none
MAX_CONCURRENT_INVESTIGATIONS=4

# Required for durable OAuth state.
# PUBLIC_BASE_URL=https://agent.example.test
# OAUTH_STATE_SECRET=long-random-state-signing-secret
# STATE_ENCRYPTION_KEY=long-random-state-encryption-key
# STATE_DB_PATH=/var/lib/slack-detective/agentkj.sqlite
# STATE_DIR=/var/lib/slack-detective

# Optional environment-provisioned OAuth app credentials. Replace SERVICE_ID with the runtime id.
# SERVICE_ID_CLIENT_ID=provider-client-id
# SERVICE_ID_CLIENT_SECRET=provider-client-secret

# Operator-only local MCP servers. Never derive commands from Slack input.
# MCP_SERVERS=[{"name":"internal-readonly","command":"node server.js"}]
