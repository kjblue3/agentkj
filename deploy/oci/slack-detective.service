[Unit]
Description=Slack Detective
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=__APP_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=/etc/slack-detective.env
ExecStart=/usr/bin/node dist/src/app.js
Restart=on-failure
RestartSec=5
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/slack-detective

[Install]
WantedBy=multi-user.target
